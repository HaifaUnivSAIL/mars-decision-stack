+#!/usr/bin/env bash
+
+set -euo pipefail
+
+ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+REPO_DIR="$(cd "${ROOT_DIR}/.." && pwd)"
+
+STACK_NAME="alate-startup"
+IMAGE="alate-ros-stack:local"
+NETWORK="${STACK_NAME}-net"
+VOLUME="${STACK_NAME}-ipc"
+ROS_DOMAIN_ID="${ROS_DOMAIN_ID:-42}"
+
+if ! docker image inspect "${IMAGE}" >/dev/null 2>&1; then
+  echo "Image ${IMAGE} was not found. Run ${ROOT_DIR}/scripts/up.sh first."
+  exit 1
+fi
+
+if ! docker network inspect "${NETWORK}" >/dev/null 2>&1; then
+  echo "Network ${NETWORK} was not found. Run ${ROOT_DIR}/scripts/up.sh first."
+  exit 1
+fi
+
+exec docker run --rm -it \
+  --name "${STACK_NAME}-decision-dev" \
+  --network "${NETWORK}" \
+  -e "ROS_DOMAIN_ID=${ROS_DOMAIN_ID}" \
+  -v "${VOLUME}:/tmp/nemala" \
+  -v "${ROOT_DIR}/config:/stack/config:ro" \
+  -v "${ROOT_DIR}/decision_ws:/workspace/decision_ws" \
+  -v "${REPO_DIR}:/workspace/alate:rw" \
+  -w /workspace/decision_ws \
+  "${IMAGE}" \
+  bash -lc "source /opt/ros/humble/setup.bash && source /opt/ros2_ws/install/setup.bash && exec bash"
