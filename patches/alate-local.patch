@@ -0,0 +1,143 @@
+name: alate-startup
+
+x-alate-ros-image: &alate-ros-image
+  build:
+    context: ..
+    dockerfile: codestack/docker/alate-ros-stack.Dockerfile
+  image: alate-ros-stack:local
+
+x-alate-service: &alate-service
+  <<: *alate-ros-image
+  restart: unless-stopped
+  volumes:
+    - ipc:/tmp/nemala
+    - ./config:/stack/config:ro
+
+services:
+  sitl:
+    image: davidovrat/arducopter-sitl:latest
+    restart: unless-stopped
+    entrypoint:
+      - /ardupilot/build/sitl/bin/arducopter
+    command:
+      - -S
+      - -I0
+      - --model
+      - +
+      - --defaults
+      - /ardupilot/Tools/autotest/default_params/copter.parm
+    networks:
+      - mav
+
+  proxy:
+    image: nemala/tools:latest
+    restart: unless-stopped
+    volumes:
+      - ipc:/tmp/nemala
+      - ./config:/stack/config:ro
+    command:
+      - proxy
+      - uav
+      - /stack/config/alate.sitl.json
+
+  logger:
+    image: nemala/tools:latest
+    restart: unless-stopped
+    depends_on:
+      - proxy
+    volumes:
+      - ipc:/tmp/nemala
+      - ./logs:/stack/logs
+    command:
+      - log
+      - ipc:///tmp/nemala/alate_log
+
+  mc:
+    <<: *alate-service
+    depends_on:
+      - proxy
+    working_dir: /opt/alate
+    command:
+      - ./mc
+      - uav
+      - /stack/config/alate.sitl.json
+
+  hlc:
+    <<: *alate-service
+    depends_on:
+      - proxy
+      - sitl
+    working_dir: /opt/alate
+    command:
+      - ./hlc
+      - uav
+      - /stack/config/alate.sitl.json
+    networks:
+      - default
+      - mav
+
+  ros-alate:
+    <<: *alate-service
+    depends_on:
+      - proxy
+      - mc
+      - hlc
+    environment:
+      ROS_DOMAIN_ID: ${ROS_DOMAIN_ID:-42}
+    command:
+      - bash
+      - -lc
+      - source /opt/ros/humble/setup.bash && source /opt/ros2_ws/install/setup.bash && ros2 run ros_alate adapter --ros-args --params-file /stack/config/adapter.yaml
+
+  ros-nemala:
+    <<: *alate-service
+    depends_on:
+      - proxy
+    environment:
+      ROS_DOMAIN_ID: ${ROS_DOMAIN_ID:-42}
+    command:
+      - bash
+      - -lc
+      - source /opt/ros/humble/setup.bash && source /opt/ros2_ws/install/setup.bash && ros2 run ros_nemala node_manager --ros-args --params-file /stack/config/node_manager.yaml
+
+  decision-dev:
+    <<: *alate-service
+    profiles:
+      - dev
+    depends_on:
+      - ros-alate
+      - ros-nemala
+    environment:
+      ROS_DOMAIN_ID: ${ROS_DOMAIN_ID:-42}
+    working_dir: /workspace/decision_ws
+    stdin_open: true
+    tty: true
+    volumes:
+      - ipc:/tmp/nemala
+      - ./config:/stack/config:ro
+      - ./decision_ws:/workspace/decision_ws
+      - ..:/workspace/alate:rw
+    command:
+      - bash
+      - -lc
+      - source /opt/ros/humble/setup.bash && source /opt/ros2_ws/install/setup.bash && sleep infinity
+
+  osc:
+    <<: *alate-service
+    profiles:
+      - ops
+    depends_on:
+      - proxy
+      - mc
+      - hlc
+    working_dir: /opt/alate
+    command:
+      - ./osc
+      - uav
+      - /stack/config/alate.sitl.json
+
+volumes:
+  ipc:
+
+networks:
+  mav:
