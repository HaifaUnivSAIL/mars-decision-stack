 #include <LlcStatusMessage.h>
 #include <StringMessage.h>
 #include <GetTimeString.h>
+#include <chrono>
 #include <stdexcept>
+#include <cstdlib>
+
+namespace
+{
+bool StartsWith(const std::string& value, const std::string& prefix)
+{
+	return value.rfind(prefix, 0) == 0;
+}
+
+bool StackProfileEnabled()
+{
+	const char * value = std::getenv("STACK_PROFILE");
+	return (value != nullptr) && (std::string(value) == "1");
+}
+
+double WallTimeEpochSec()
+{
+	using clock = std::chrono::system_clock;
+	return std::chrono::duration<double>(clock::now().time_since_epoch()).count();
+}
+
+std::string EscapeJson(const std::string& text)
+{
+	std::string escaped;
+	escaped.reserve(text.size() + 8);
+	for (char ch : text)
+	{
+		switch (ch)
+		{
+			case '\\':
+				escaped += "\\\\";
+				break;
+			case '"':
+				escaped += "\\\"";
+				break;
+			case '\n':
+				escaped += "\\n";
+				break;
+			case '\r':
+				escaped += "\\r";
+				break;
+			case '\t':
+				escaped += "\\t";
+				break;
+			default:
+				escaped += ch;
+				break;
+		}
+	}
+	return escaped;
+}
+
+void EmitProfile(const std::string& event_type, const std::string& payload_json)
+{
+	if (!StackProfileEnabled())
+	{
+		return;
+	}
+	std::cout << "PROFILE:{\"component\":\"autopilot\",\"event_type\":\""
+		<< event_type << "\",\"wall_time_epoch_sec\":" << WallTimeEpochSec()
+		<< "," << payload_json << "}" << std::endl;
+}
+
+bool ShouldPublishAsPlatformError(const std::string& line)
+{
+	return StartsWith(line, "CRITICAL:") ||
+		StartsWith(line, "ERROR:") ||
+		StartsWith(line, "WARNING:") ||
+		StartsWith(line, "Traceback") ||
+		(std::string::npos != line.find("RuntimeError")) ||
+		(std::string::npos != line.find("couldn't initialize")) ||
+		(std::string::npos != line.find("Link timeout, no heartbeat"));
+}
+}
