new file mode 100644
index 0000000..c35bcce
--- /dev/null
+++ b/codestack/docker/alate-ros-stack.Dockerfile
@@ -0,0 +1,94 @@
+FROM ros:humble AS builder
+
+ENV DEBIAN_FRONTEND=noninteractive
+
+SHELL ["/bin/bash", "-lc"]
+
+ARG ROS_ALATE_REF=652db08738a29a5b126dee8b63bec1e63c1b7030
+ARG ROS_ALATE_INTERFACES_REF=76f8c7b822a49ccd294f5aff2855ef929f2ce119
+ARG ROS_NEMALA_REF=628c28c926c6c8abc24e0e88d82bd2591f5b9d15
+ARG ROS_NEMALA_INTERFACES_REF=acf9a2fb886242612dfe4b4bde44803b4e0cc5e8
+
+RUN apt-get update && apt-get install -y --no-install-recommends \
+    build-essential \
+    cmake \
+    ffmpeg \
+    git \
+    libboost-all-dev \
+    libzmq3-dev \
+    python3-colcon-common-extensions \
+    python3-pip \
+    ros-humble-ament-cmake \
+    ros-humble-geometry-msgs \
+    ros-humble-rosidl-default-generators \
+    wget \
+    && rm -rf /var/lib/apt/lists/*
+
+RUN python3 -m pip install --no-cache-dir --upgrade pip && \
+    python3 -m pip install --no-cache-dir pyzmq lxml
+
+WORKDIR /tmp
+
+RUN wget -q https://gitlab.com/nemala/core/-/archive/version_0_1/core-version_0_1.tar.gz && \
+    tar -xf core-version_0_1.tar.gz && \
+    cmake -S /tmp/core-version_0_1/src -B /tmp/core-build && \
+    cmake --build /tmp/core-build --parallel && \
+    cmake --install /tmp/core-build
+
+WORKDIR /opt/src/alate
+
+COPY . /opt/src/alate
+
+RUN python3 -m pip install --no-cache-dir -r /opt/src/alate/src/HighLevelControl/AutoPilots/requirements.txt && \
+    cmake -S /opt/src/alate/src -B /tmp/alate-build \
+      -DNeMALA_INCLUDE_DIR=/usr/local/include \
+      -DNeMALA_LIBRARY_PATH=/usr/local/lib \
+      -DCMAKE_INSTALL_PREFIX=/opt/alate \
+      -DALATE_BUILD_MC=ON \
+      -DALATE_BUILD_HLC=ON \
+      -DALATE_BUILD_OSC=ON \
+      -DALATE_BUILD_BMA=ON && \
+    cmake --build /tmp/alate-build --parallel && \
+    cmake --install /tmp/alate-build
+
+WORKDIR /opt/ros2_ws/src
+
+RUN git clone --depth 1 https://github.com/MARS-Technion/ros_alate_interfaces.git && \
+    git -C ros_alate_interfaces checkout "${ROS_ALATE_INTERFACES_REF}" && \
+    git clone --depth 1 https://github.com/MARS-Technion/ros_nemala_interfaces.git && \
+    git -C ros_nemala_interfaces checkout "${ROS_NEMALA_INTERFACES_REF}" && \
+    git clone --depth 1 https://github.com/MARS-Technion/ros_alate.git && \
+    git -C ros_alate checkout "${ROS_ALATE_REF}" && \
+    git clone --depth 1 https://github.com/MARS-Technion/ros_nemala.git && \
+    git -C ros_nemala checkout "${ROS_NEMALA_REF}"
+
+WORKDIR /opt/ros2_ws
+
+RUN source /opt/ros/humble/setup.bash && \
+    colcon build --merge-install
+
+FROM ros:humble
+
+ENV DEBIAN_FRONTEND=noninteractive
+ENV LD_LIBRARY_PATH=/usr/local/lib:${LD_LIBRARY_PATH}
+
+SHELL ["/bin/bash", "-lc"]
+
+RUN apt-get update && apt-get install -y --no-install-recommends \
+    ffmpeg \
+    libboost-all-dev \
+    libzmq5 \
+    python3-pip \
+    ros-humble-geometry-msgs \
+    ros-humble-rosidl-default-runtime \
+    && rm -rf /var/lib/apt/lists/*
+
+COPY --from=builder /usr/local /usr/local
+COPY --from=builder /opt/alate /opt/alate
+COPY --from=builder /opt/ros2_ws/install /opt/ros2_ws/install
+
+RUN ldconfig
+
+WORKDIR /opt/alate
+
+CMD ["bash"]
