+#!/usr/bin/env bash
+
+set -euo pipefail
+
+ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+REPO_DIR="$(cd "${ROOT_DIR}/.." && pwd)"
+
+STACK_NAME="alate-startup"
+IMAGE="alate-ros-stack:local"
+NETWORK="${STACK_NAME}-net"
+VOLUME="${STACK_NAME}-ipc"
+ROS_DOMAIN_ID="${ROS_DOMAIN_ID:-42}"
+
+CONFIG_DIR="${ROOT_DIR}/config"
+LOG_DIR="${ROOT_DIR}/logs"
+
+containers=(
+  "${STACK_NAME}-decision-dev"
+  "${STACK_NAME}-osc"
+  "${STACK_NAME}-ros-nemala"
+  "${STACK_NAME}-ros-alate"
+  "${STACK_NAME}-hlc"
+  "${STACK_NAME}-mc"
+  "${STACK_NAME}-logger"
+  "${STACK_NAME}-proxy"
+  "${STACK_NAME}-sitl"
+)
+
+mkdir -p "${LOG_DIR}"
+
+for container in "${containers[@]}"; do
+  docker rm -f "${container}" >/dev/null 2>&1 || true
+done
+
+docker volume inspect "${VOLUME}" >/dev/null 2>&1 || docker volume create "${VOLUME}" >/dev/null
+docker network inspect "${NETWORK}" >/dev/null 2>&1 || docker network create "${NETWORK}" >/dev/null
+
+docker build \
+  -t "${IMAGE}" \
+  -f "${ROOT_DIR}/docker/alate-ros-stack.Dockerfile" \
+  "${REPO_DIR}"
+
+docker run -d --rm \
+  --name "${STACK_NAME}-sitl" \
+  --network "${NETWORK}" \
+  --network-alias sitl \
+  --entrypoint /ardupilot/build/sitl/bin/arducopter \
+  davidovrat/arducopter-sitl:latest \
+  -S \
+  -I0 \
+  --model + \
+  --defaults /ardupilot/Tools/autotest/default_params/copter.parm
+
+docker run -d --rm \
+  --name "${STACK_NAME}-proxy" \
+  --network "${NETWORK}" \
+  -v "${VOLUME}:/tmp/nemala" \
+  -v "${CONFIG_DIR}:/stack/config:ro" \
+  nemala/tools:latest \
+  proxy uav /stack/config/alate.sitl.json
+
+docker run -d --rm \
+  --name "${STACK_NAME}-logger" \
+  --network "${NETWORK}" \
+  -v "${VOLUME}:/tmp/nemala" \
+  -v "${LOG_DIR}:/stack/logs" \
+  nemala/tools:latest \
+  log ipc:///tmp/nemala/alate_log
+
+sleep 2
+
+docker run -d --rm \
+  --name "${STACK_NAME}-mc" \
+  --network "${NETWORK}" \
+  -w /opt/alate \
+  -v "${VOLUME}:/tmp/nemala" \
+  -v "${CONFIG_DIR}:/stack/config:ro" \
+  "${IMAGE}" \
+  ./mc uav /stack/config/alate.sitl.json
+
+docker run -d --rm \
+  --name "${STACK_NAME}-hlc" \
+  --network "${NETWORK}" \
+  -w /opt/alate \
+  -v "${VOLUME}:/tmp/nemala" \
+  -v "${CONFIG_DIR}:/stack/config:ro" \
+  "${IMAGE}" \
+  ./hlc uav /stack/config/alate.sitl.json
+
+sleep 2
+
+docker run -d --rm \
+  --name "${STACK_NAME}-ros-alate" \
+  --network "${NETWORK}" \
+  -e "ROS_DOMAIN_ID=${ROS_DOMAIN_ID}" \
+  -v "${VOLUME}:/tmp/nemala" \
+  -v "${CONFIG_DIR}:/stack/config:ro" \
+  "${IMAGE}" \
+  bash -lc "source /opt/ros/humble/setup.bash && source /opt/ros2_ws/install/setup.bash && ros2 run ros_alate adapter --ros-args --params-file /stack/config/adapter.yaml"
+
+docker run -d --rm \
+  --name "${STACK_NAME}-ros-nemala" \
+  --network "${NETWORK}" \
+  -e "ROS_DOMAIN_ID=${ROS_DOMAIN_ID}" \
+  -v "${VOLUME}:/tmp/nemala" \
+  -v "${CONFIG_DIR}:/stack/config:ro" \
