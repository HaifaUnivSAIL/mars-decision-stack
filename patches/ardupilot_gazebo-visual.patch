+<?xml version="1.0"?>
+
+<model>
+  <name>Iris with Camera Calibration</name>
+  <version>1.0</version>
+  <sdf version="1.9">model.sdf</sdf>
+
+  <author>
+    <name>MARS Decision Stack</name>
+  </author>
+
+  <description>
+    Iris quadrotor with a rigid front-bottom deployed camera calibration rig.
+    The visible payload is a fixed camera pod, while invisible helper joints
+    expose 6-DOF tuning controls for calibration only.
+  </description>
+  <depend>
+    <model>
+      <uri>model://iris_with_standoffs</uri>
+      <version>2.0</version>
+    </model>
+  </depend>
+</model>
