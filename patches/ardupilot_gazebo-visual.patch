+  /// \brief Initialise per-model profiling output from the environment.
+  public: void ConfigureProfileOutput()
+  {
+    const char *stackProfile = std::getenv("STACK_PROFILE");
+    if (nullptr == stackProfile || std::string(stackProfile) != "1")
+    {
+      return;
+    }
+
+    const char *runDir = std::getenv("STACK_PROFILE_RUN_DIR");
+    if (nullptr == runDir || std::string(runDir).empty())
+    {
+      return;
+    }
+
+    std::filesystem::path outputDir(runDir);
+    outputDir /= "diagnostics";
+    outputDir /= "profile";
+    outputDir /= "fdm_exchange";
+    std::error_code ec;
+    std::filesystem::create_directories(outputDir, ec);
+    if (ec)
+    {
+      gzwarn << "[" << this->modelName << "] "
+             << "Failed to create FDM profile directory: "
+             << outputDir.string() << "\n";
+      return;
+    }
+
+    const auto fileName = sanitizeName(this->modelName) + ".csv";
+    auto outputPath = outputDir / fileName;
+    this->profileStream.open(outputPath, std::ios::out | std::ios::trunc);
+    if (!this->profileStream.is_open())
+    {
+      gzwarn << "[" << this->modelName << "] "
+             << "Failed to open FDM profile output: "
+             << outputPath.string() << "\n";
+      return;
+    }
+
+    this->profileStream
+      << "wall_time_epoch_sec,monotonic_sec,sim_time_sec,model_name,event,"
+      << "wait_ms,duration_sec,recv_size,drained_packets,frame_count,frame_rate,"
+      << "skipped_frames,connection_timeout_count,online,fdm_port_in,fcu_port_out,bytes_sent\n";
+    this->profileStream.flush();
+    this->profileLastFlushWallTimeSec = 0.0;
+    this->profileEnabled = true;
+  }
+
+  /// \brief Record an FDM exchange event for later analysis.
+  public: void LogProfileEvent(
+      const std::string &_event,
+      uint32_t _waitMs,
+      double _durationSec,
+      ssize_t _recvSize,
+      int _drainedPackets,
+      int64_t _frameCount,
+      int64_t _frameRate,
+      int64_t _skippedFrames,
+      ssize_t _bytesSent)
+  {
+    if (!this->profileEnabled || !this->profileStream.is_open())
+    {
+      return;
+    }
+
+    const auto wallNow = std::chrono::system_clock::now();
+    const auto monotonicNow = std::chrono::steady_clock::now();
+    const auto wallSec =
+      std::chrono::duration<double>(wallNow.time_since_epoch()).count();
+    const auto monotonicSec =
+      std::chrono::duration<double>(monotonicNow.time_since_epoch()).count();
+
+    this->profileStream
+      << std::fixed << std::setprecision(6)
+      << wallSec << ","
+      << monotonicSec << ","
+      << this->profileSimTimeSec << ","
+      << this->modelName << ","
+      << _event << ","
+      << _waitMs << ","
+      << _durationSec << ","
+      << _recvSize << ","
+      << _drainedPackets << ","
+      << _frameCount << ","
+      << _frameRate << ","
+      << _skippedFrames << ","
+      << this->connectionTimeoutCount << ","
+      << (this->arduPilotOnline ? 1 : 0) << ","
+      << this->fdm_port_in << ","
+      << this->fcu_port_out << ","
+      << _bytesSent << "\n";
+
+    if ((wallSec - this->profileLastFlushWallTimeSec) >= 1.0)
+    {
+      this->profileStream.flush();
+      this->profileLastFlushWallTimeSec = wallSec;
+    }
+  }
 };
 
