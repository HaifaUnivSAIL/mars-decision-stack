+*/
+
+#include "ros_alate/handlers/high_level_control_telemetry_handler.h"
+#include "ros_alate_interfaces/LlcStatusMessage.hpp"
+
+namespace ros_alate {
+
+void HighLevelControlTelemetryHandler::Handle(NeMALA::Proptree pt)
+{
+  ros_alate_interfaces::LlcStatusMessage msg(pt);
+  ros_alate_interfaces::LlcStatusMessage::LlcStateStruct llc = msg.GetLlcStatus();
+  ros_alate_interfaces::msg::HlcTelemetry ros_msg;
+  ros_msg.latitude = llc.dLatitude;
+  ros_msg.longitude = llc.dLongitude;
+  ros_msg.altitude = llc.dAltitude;
+  ros_msg.yaw = llc.dYaw;
+  ros_msg.armed = llc.bArmed;
+  ros_msg.battery_voltage = llc.dBatteryVoltage;
+  ros_msg.gps_fix = static_cast<decltype(ros_msg.gps_fix)>(llc.nGpsFix);
+  ros_msg.gps_hdop = llc.dGpsHdop;
+  ros_msg.mode = llc.strMode;
+  ros_msg.state = llc.strState;
+  m_pPublisher->publish(ros_msg);
+}
+
+} // namespace ros_alate
